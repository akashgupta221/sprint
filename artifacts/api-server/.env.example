# Local API server environment file.
# Copy to .env and fill in real values locally.

PORT=3000
DATABASE_URL=postgres://user:password@localhost:5432/sprint
SESSION_SECRET=replace-with-a-secret
CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here
NODE_ENV=development

# Optional SMTP settings for real email delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Sprint <no-reply@sprint.local>"
