# Copy this file to .env and fill in the real values for your local environment.

# Database connection (required)
DATABASE_URL=postgres://user:password@localhost:5432/sprint

# API server
PORT=3000
SESSION_SECRET=replace-with-a-secret-string

# SMTP / email delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Sprint <no-reply@sprint.local>"
NOTIFICATION_POLL_MS=5000
NOTIFICATION_BATCH_SIZE=10

# Clerk / frontend auth configuration
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
VITE_CLERK_PROXY_URL=
BASE_PATH=/